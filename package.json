{
	"name": "mysync",
	"version": "0.1.12",
	"description": "An Obsidian plugin for syncing files with your personal server.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"syncing"
	],
	"author": "",
	"license": "MIT",
	"engines": {
		"node": ">=22.22.0"
	},
	"devDependencies": {
		"@types/node": "^22.15.0",
		"esbuild": "0.25.5",
		"tslib": "2.8.1",
		"typescript": "^5.8.3"
	},
	"dependencies": {
		"obsidian": "^1.13.1",
		"pouchdb": "^9.0.0"
	},
	"overrides": {
		"uuid": "11.1.1"
	}
}
